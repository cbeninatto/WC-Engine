# Only the runtime agents need this. The engine + DB are fully local.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: human-in-the-loop notifications (reuse your Fastmail-agent bot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Backend ---------------------------------------------------------------
# Leave DATABASE_URL unset to use the local SQLite file (wc.db).
# Set it to your Supabase *pooler* connection string to use Postgres (serverless-safe):
#   postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
# DATABASE_URL=

# --- Dashboard control on Vercel -------------------------------------------
# So the dashboard's "Run monitor" button can fire the GitHub Actions workflow
# (serverless can't run the long web-search agent itself). Token needs actions:write.
# GITHUB_DISPATCH_TOKEN=
# GITHUB_REPO=cbeninatto/WC-Engine

# --- Optional overrides ------------------------------------------------------
# WC_DB_PATH=./wc.db
# WC_AGENT_MODEL=claude-sonnet-4-6
# WC_XLSX_PATH=../WorldCup2026_Analytics_Companion.xlsx
# WC_WEB_PORT=8000
